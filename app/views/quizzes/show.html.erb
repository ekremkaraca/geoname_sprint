<div
  data-controller="quiz"
  data-quiz-city-lookup-value="<%= @quiz.city_lookup.to_json %>"
  data-quiz-guess-lookup-value="<%= @quiz.city_guess_lookup.to_json %>"
  data-quiz-city-coordinates-value="<%= @quiz.city_coordinates.to_json %>"
  data-quiz-duration-value="<%= @quiz.duration_seconds %>"
  data-quiz-city-count-value="<%= @quiz.city_count %>"
  data-quiz-map-center-value="<%= @quiz.map_center.to_json %>"
  data-quiz-map-zoom-value="<%= @quiz.map_zoom %>"
  data-quiz-all-city-names-value="<%= @quiz.city_names.to_json %>"
>
  <header class="game-header">
    <div>
      <%= link_to "All quizzes", root_path, class: "back-link secondary" %>
      <h1><%= @quiz.title %></h1>
    </div>

    <div class="scoreboard" aria-label="Quiz status">
      <article>
        <small>Found</small>
        <span data-quiz-target="count">0</span>/<%= @quiz.city_count %>
      </article>

      <article>
        <small>Percentage</small>
        <span data-quiz-target="percentage">0%</span>
      </article>

      <article>
        <small>Time left</small>
        <span data-quiz-target="timer">05:00</span>
      </article>
    </div>
  </header>

  <section class="game-layout">
    <div
      id="map"
      class="map-panel"
      data-quiz-target="map"
    ></div>

    <aside class="guess-panel" aria-label="Guess cities">
      <div>
        <label for="city_guess">City guess</label>
        <input
          id="city_guess"
          name="city_guess"
          type="text"
          placeholder="Enter a city..."
          data-quiz-target="input"
          data-action="keydown.enter->quiz#guess"
          autocomplete="off"
        >
      </div>

      <div class="found-list">
        <h2>Found cities</h2>
        <ul data-quiz-target="results">
        </ul>
      </div>

      <article class="outcome-panel" data-quiz-target="outcome" hidden></article>
    </aside>
  </section>

</div>
