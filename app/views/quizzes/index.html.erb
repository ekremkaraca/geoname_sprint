<header class="page-header">
  <p class="eyebrow">Geography quiz</p>
  <h1>GeoName Sprint</h1>
  <p class="lede">Type as many city names as you can before the clock runs out.</p>
</header>

<div class="quiz-list" aria-label="Available quizzes">
  <% @quizzes.each do |quiz| %>
    <section class="quiz-card">
      <div>
        <h2>
          <%= link_to quiz.title, quiz_path(quiz.slug), class: "quiz-card__link" %>
        </h2>
        <p class="muted">Find every city in this sprint.</p>
      </div>

      <dl class="quiz-meta">
        <div>
          <dt>Cities</dt>
          <dd><%= quiz.city_count %></dd>
        </div>

        <div>
          <dt>Time</dt>
          <dd><%= quiz.duration_minutes %> min</dd>
        </div>
      </dl>
    </section>
  <% end %>
</div>
