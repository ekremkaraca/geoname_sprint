<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>GeoName Sprint</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "leaflet", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "pico.min", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="topbar container">
      <nav>
        <ul>
          <li><strong><%= link_to "GeoName Sprint", root_path, class: "brand-link" %></strong></li>
        </ul>

        <ul>
          <li>
            <button
              class="theme-toggle secondary outline"
              type="button"
              data-theme-toggle
              aria-label="Toggle light mode"
            >
              Light
            </button>
          </li>
        </ul>
      </nav>
    </header>

    <main class="app-shell container">
      <%= yield %>
    </main>
  </body>
</html>
