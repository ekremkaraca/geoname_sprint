<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>GeoName Sprint</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="topbar">
      <%= link_to "GeoName Sprint", root_path, class: "brand-link" %>

      <button
        class="theme-toggle"
        type="button"
        data-theme-toggle
        aria-label="Toggle light mode"
      >
        Light
      </button>
    </header>

    <main class="app-shell">
      <%= yield %>
    </main>
  </body>
</html>
