root ::= "[" ws city ("," ws city)* "]" ws

city ::= "{" ws "\"name\":" ws string "," ws "\"aliases\":" ws string_array "," ws "\"map_latitude\":" ws number "," ws "\"map_longitude\":" ws number ws "}"

string ::= "\"" [a-zA-Z0-9 -]+ "\""
string_array ::= "[" ws string ("," ws string)* "]"
number ::= "-"?[0-9]+ "." [0-9]+
ws ::= [ \t\n]*
